# Copy this file to backend/.env and adjust as needed.

# HTTP server port
PORT=3000

# MongoDB connection string (points at the docker-compose mongo service)
MONGO_URI=mongodb://localhost:27017/flashsale

# Redis connection string (points at the docker-compose redis service)
REDIS_URL=redis://localhost:6379

# How long a cart reservation is held before it auto-expires and stock is
# returned. Dynamic — never hardcode this in the app. Default 600s (10 min).
RESERVATION_TTL_SECONDS=600

# Comma-separated allowed CORS origins for the Angular dev server
CORS_ORIGIN=http://localhost:4200
